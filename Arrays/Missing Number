class Solution {
    int missingNum(int a1[]) {
        Arrays.sort(a1);
        
        if(a1[0] != 1){
            return 1;
        }
        for(int i = 0; i < a1.length - 1; i++){
            if(a1[i] + 1 != a1[i+1]){
                return a1[i] + 1;
            }
        }
        return a1[a1.length - 1] + 1;
    }
}